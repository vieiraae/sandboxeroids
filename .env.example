# Copy to .env and fill in.
# The Azure CLI credential (az login) is used automatically — no principal id needed.

# az account show --query id -o tsv
ACA_SUBSCRIPTION_ID=
ACA_RESOURCE_GROUP=sandboxeroids-rg
ACA_SANDBOX_GROUP=sandboxeroids
ACA_REGION=westus3

# Warm pool size — how many real sandboxes to keep alive for instant asteroid spawn
WARM_POOL_SIZE=3

# Lifecycle policy applied to every sandbox. Set seconds to 0 to disable.
ACA_AUTO_SUSPEND_SECONDS=120
ACA_AUTO_SUSPEND_MODE=Memory
ACA_AUTO_DELETE_SECONDS=600

# Player starting lives
STARTING_LIVES=6

# Public disk images to use (comma-separated). Leave empty / unset to use
# every image the sandbox group exposes that we have an icon for.
# Example: ACA_DISK_IMAGES=ubuntu-22.04,python-3.12,node-20,dotnet-8
ACA_DISK_IMAGES=copilot, ubuntu, dotnet-10, python-3.14, node-24
